MONGODB_URL=mongodb://localhost:27017
DATABASE_NAME=placement_db

# SECURITY: Generate strong secret keys for production
# Use: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
REFRESH_SECRET_KEY=your-refresh-secret-key-change-in-production-min-32-chars

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS: Use production domain in production (comma-separated for multiple origins)
# Example production: ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=5

# ENVIRONMENT: Set to "production" when deploying
ENVIRONMENT=development

# Cloudinary Cloud Storage (REQUIRED in production)
# Sign up at: https://cloudinary.com/
CLOUDINARY_CLOUD_NAME=your_cloud_name_here
CLOUDINARY_API_KEY=your_api_key_here
CLOUDINARY_API_SECRET=your_api_secret_here

# SMTP Email Configuration (Optional - for password reset emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_specific_password
SMTP_FROM=SmartHire <noreply@smarthire.com>
SMTP_TLS=true

# App Base URL (used in password-reset links)
APP_BASE_URL=http://localhost:3000

# AI Resume Analyzer
# Google Gemini (PRIMARY - free, reliable: https://aistudio.google.com/apikey)
GOOGLE_GEMINI_API_KEY=your_gemini_api_key_here
# OpenRouter (FALLBACK - free models, may be rate-limited)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Multi-Agent AI System (LangChain + LangGraph + LangSmith)
# OpenAI API (Required for Resume Extraction & Job Matching Agents)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Mistral AI (used for mock interview chat)
# Get your API key from: https://console.mistral.ai/
MISTRAL_API_KEY=your_mistral_api_key_here

# LangSmith Tracing & Monitoring (Optional but Recommended for Production)
# Sign up at: https://smith.langchain.com/
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=smarthire-portal
